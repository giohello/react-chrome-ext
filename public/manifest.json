{
  "manifest_version": 3,
  "name": "Blind Helper",
  "version": "1.0.0",
  "description": "Accessible Chrome extension that announces hovered and focused page elements for blind users.",
  "permissions": ["tabs", "activeTab", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}
